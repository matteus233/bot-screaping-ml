# ════════════════════════════════════════════════
#  COMO OBTER AS CREDENCIAIS DO MERCADO LIVRE
# ════════════════════════════════════════════════
#
#  PASSO 1 — Criar o App
#  ─────────────────────
#  1. Acesse: https://developers.mercadolivre.com.br/devcenter
#  2. Clique em "Criar nova aplicação"
#  3. Escopos necessários: read
#  4. Redirect URI: http://localhost/callback
#  5. Copie o App ID e o Client Secret
#
#  PASSO 2 — Autorizar (OAuth 2.0, só uma vez)
#  ─────────────────────────────────────────────
#  1. Preencha ML_APP_ID e ML_CLIENT_SECRET abaixo
#  2. Rode: npm run dev
#     O bot vai imprimir a URL de autorização no terminal
#  3. Abra a URL no navegador e clique em "Permitir"
#  4. Copie o ?code= da URL de redirecionamento
#  5. Cole temporariamente em src/main.ts:
#       await tokenManager.exchangeCode('TG-XXXXXXXXXX')
#  6. O bot vai imprimir ACCESS e REFRESH tokens — cole abaixo
#  7. Remova a linha do exchangeCode — pronto!
#
#  RENOVAÇÃO: o access_token dura 6h. O bot renova automaticamente.
#
# ════════════════════════════════════════════════

# ─────────────────────────────────────────
#  Mercado Livre OAuth (obrigatório)
# ─────────────────────────────────────────
ML_APP_ID=1234567890
ML_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx
ML_REDIRECT_URI=http://localhost/callback
ML_ACCESS_TOKEN=        # preenchido após OAuth
ML_REFRESH_TOKEN=       # preenchido após OAuth

# ─────────────────────────────────────────
#  Telegram (obrigatório)
# ─────────────────────────────────────────
#
#  BOT TOKEN:
#  1. Abra o @BotFather no Telegram
#  2. Envie /newbot e siga as instruções
#  3. Copie o token gerado
#
#  CHANNEL ID:
#  1. Crie um canal no Telegram
#  2. Adicione o bot como administrador com permissão de postar
#  3. Envie qualquer mensagem no canal
#  4. Abra no navegador:
#     https://api.telegram.org/bot<SEU_TOKEN>/getUpdates
#  5. Procure "chat":{"id": -100XXXXXXXXXX} — esse é o channel_id
#
TELEGRAM_BOT_TOKEN=123456789:AAF-XXXXXXXXXXXXXXXXXXXXXXXXXXX
TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx

# ─────────────────────────────────────────
#  PostgreSQL (obrigatório)
# ─────────────────────────────────────────
# Local:
DATABASE_URL=postgresql://postgres:senha@localhost:5432/ml_promo_bot
# Cloud (Supabase / Railway / Render):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# ─────────────────────────────────────────
#  Geral
# ─────────────────────────────────────────
LOG_LEVEL=info   # debug | info | warn | error